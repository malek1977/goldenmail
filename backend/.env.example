# ===== Server =====
NODE_ENV=development
PORT=5000

# ===== Database (SQLite) =====
DATABASE_URL="file:./prisma/dev.db"

# ===== JWT Auth =====
# ⚠️ ضع قيمة عشوائية قوية (32 حرف على الأقل) في الإنتاج
JWT_SECRET="change-this-to-a-very-long-random-secret-min-32-chars"
JWT_EXPIRES_IN="7d"

# ===== CORS =====
# ضع كل الـ origins المسموح لها بالوصول للـ API
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,https://goldmil.matrxe.com,https://www.goldmil.matrxe.com"

# ===== Admin Defaults (للسكربت seed) =====
ADMIN_EMAIL="admin@goldenmile.com.sa"
ADMIN_PASSWORD="Admin@2026"
ADMIN_NAME="أحمد العتيبي"

# ===== Public Site =====
PUBLIC_SITE_URL="https://goldmil.matrxe.com"